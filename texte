<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LegacyC7 - Impulsionar Perfil</title>

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #0a0a0f;
  color: #fff;
  font-family: 'Arial', sans-serif;
  padding-bottom: 80px;
}

/* TOPO */
.topbar {
  background: #12121a;
  padding: 15px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid #1f1f2e;
}

.logo {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 18px;
  font-weight: bold;
}

.logo span {
  color: #3b82f6;
}

.icons {
  display: flex;
  gap: 12px;
  font-size: 18px;
}

.icon-btn {
  background: #1e1e2d;
  border: none;
  border-radius: 8px;
  width: 36px;
  height: 36px;
  color: #fff;
  cursor: pointer;
}

/* CONTEÚDO */
.container {
  padding: 20px 15px;
}

h1 {
  font-size: 24px;
  margin-bottom: 5px;
}

.subtitle {
  color: #9ca3af;
  font-size: 14px;
  margin-bottom: 20px;
}

/* CARD ENVIAR LIKES */
.card {
  background: #12121a;
  border: 1px solid #1f1f2e;
  border-radius: 16px;
  padding: 18px;
  margin-bottom: 20px;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 15px;
}

.card-title {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 16px;
  font-weight: bold;
}

.badge {
  background: #1e40af;
  color: #fff;
  padding: 4px 10px;
  border-radius: 20px;
  font-size: 12px;
}

label {
  display: block;
  color: #9ca3af;
  font-size: 12px;
  margin-bottom: 8px;
  text-transform: uppercase;
}

.input-box {
  background: #0a0a0f;
  border: 1px solid #1f1f2e;
  border-radius: 10px;
  padding: 12px;
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.input-box input {
  background: none;
  border: none;
  outline: none;
  color: #fff;
  width: 100%;
  font-size: 14px;
}

.hint {
  color: #6b7280;
  font-size: 12px;
  margin-bottom: 15px;
}

.alert {
  background: #1e3a2e;
  border: 1px solid #065f46;
  border-radius: 10px;
  padding: 12px;
  display: flex;
  gap: 10px;
  font-size: 13px;
  margin-bottom: 15px;
}

.btn-primary {
  width: 100%;
  background: #2563eb;
  color: #fff;
  border: none;
  padding: 14px;
  border-radius: 10px;
  font-weight: bold;
  font-size: 15px;
  cursor: pointer;
  transition: .2s;
}

.btn-primary:hover {
  background: #1d4ed8;
}

.btn-primary:disabled {
  background: #374151;
  cursor: not-allowed;
}

/* CARD REGRAS */
.info-item {
  display: flex;
  gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid #1f1f2e;
}

.info-item:last-child {
  border-bottom: none;
}

.info-icon {
  width: 40px;
  height: 40px;
  background: #1e1e2d;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}

.info-text h3 {
  font-size: 14px;
  margin-bottom: 3px;
}

.info-text p {
  font-size: 12px;
  color: #9ca3af;
}

/* COMO FUNCIONA + DICAS */
.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-top: 10px;
}

.section h3 {
  font-size: 15px;
  margin-bottom: 12px;
}

.section ol, .section ul {
  padding-left: 18px;
  color: #d1d5db;
  font-size: 13px;
  line-height: 1.8;
}

/* NAV INFERIOR */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #12121a;
  border-top: 1px solid #1f1f2e;
  display: flex;
  justify-content: space-around;
  padding: 10px 0;
  z-index: 998;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  color: #6b7280;
  text-decoration: none;
  font-size: 11px;
}

.nav-item.active {
  color: #3b82f6;
}

.nav-item span {
  font-size: 18px;
}

/* CHAT FLUTUANTE */
.chat-btn {
  position: fixed;
  bottom: 85px;
  right: 20px;
  background: #3b82f6;
  width: 55px;
  height: 55px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  text-decoration: none;
  box-shadow: 0 4px 15px rgba(59, 130, 246, 0.4);
  z-index: 997;
}
</style>
</head>

<body>

<!-- TOPO -->
<div class="topbar">
  <div class="logo">
    <span>LC</span> Legacy<span>C7</span>
  </div>
  <div class="icons">
    <button class="icon-btn">🔔</button>
    <button class="icon-btn">☰</button>
    <button class="icon-btn">🔴</button>
    <button class="icon-btn">✏️</button>
    <button class="icon-btn">❤️</button>
  </div>
</div>

<div class="container">
  <h1>Impulsionar Perfil</h1>
  <p class="subtitle">Envie likes instantâneos para sua conta do Free Fire.</p>

  <!-- CARD ENVIAR LIKES -->
  <div class="card">
    <div class="card-header">
      <div class="card-title">
        💙 Enviar Likes
      </div>
      <div class="badge" id="contador">Likes: 1/2</div>
    </div>

    <label>UID DO JOGADOR</label>
    <div class="input-box">
      <span>📋</span>
      <input type="number" id="uid" placeholder="Digite o UID do Free Fire">
    </div>
    <p class="hint">O UID deve conter apenas números.</p>

    <div class="alert">
      <span>🛡️</span>
      <div>
        <strong>Sistema Anti-Ban Ativo</strong><br>
        O envio feito de forma segura respeitando os limites do jogo.
      </div>
    </div>

    <button class="btn-primary" onclick="enviarLike()" id="btnEnviar">
      ⚡ INICIAR ENVIO AGORA
    </button>
  </div>

  <!-- CARD REGRAS -->
  <div class="card">
    <div class="card-title" style="margin-bottom:15px;">
      ℹ️ Regras de Envio
    </div>

    <div class="info-item">
      <div class="info-icon">🔄</div>
      <div class="info-text">
        <h3>Intervalo de 24h</h3>
        <p>Cada UID pode receber likes uma vez a cada 24 horas.</p>
      </div>
    </div>

    <div class="info-item">
      <div class="info-icon">✅</div>
      <div class="info-text">
        <h3>Confirmação Real</h3>
        <p>Os likes aparecem no seu perfil em até 5 minutos.</p>
      </div>
    </div>
  </div>

  <!-- COMO FUNCIONA + DICAS -->
  <div class="grid-2">
    <div class="section">
      <h3>Como Funciona</h3>
      <ol>
        <li>Insira seu UID (ID numérico) do Free Fire</li>
        <li>Clique em "INICIAR ENVIO" e pronto!</li>
        <li>Aguarde o ciclo de 24h para novo envio</li>
      </ol>
    </div>

    <div class="section">
      <h3>Dicas</h3>
      <ul>
        <li>Verifique se o UID está correto</li>
        <li>Respeite o intervalo de 24 horas por ID</li>
      </ul>
    </div>
  </div>
</div>

<!-- BOTÃO CHAT -->
<a href="#" class="chat-btn">💬</a>

<!-- NAV INFERIOR -->
<div class="bottom-nav">
  <a href="#" class="nav-item">
    <span>🏠</span>INÍCIO
  </a>
  <a href="#" class="nav-item active">
    <span>💙</span>LIKES
  </a>
  <a href="#" class="nav-item">
    <span>💎</span>PLANOS
  </a>
  <a href="#" class="nav-item">
    <span>🔄</span>HISTÓRICO
  </a>
  <a href="#" class="nav-item">
    <span>👤</span>PERFIL
  </a>
  <a href="#" class="nav-item">
    <span>ℹ️</span>INFO
  </a>
  <a href="#" class="nav-item">
    <span>📝</span>BIO
  </a>
  <a href="#" class="nav-item">
    <span>🚪</span>SAIR
  </a>
</div>

<script>
let likesRestantes = 1;
let maxLikes = 2;

function enviarLike(){
  let uid = document.getElementById('uid').value;
  let btn = document.getElementById('btnEnviar');
  
  if(!uid){
    alert('Digite um UID válido!');
    return;
  }
  
  if(uid.length < 8){
    alert('UID muito curto! Verifique se está correto.');
    return;
  }
  
  if(likesRestantes <= 0){
    alert('Você já usou seus 2 likes hoje. Volte em 24h!');
    return;
  }
  
  // Simula envio
  btn.disabled = true;
  btn.innerHTML = '⏳ Enviando...';
  
  setTimeout(() => {
    likesRestantes--;
    document.getElementById('contador').innerText = `Likes: ${likesRestantes}/${maxLikes}`;
    alert(`✅ Likes enviados com sucesso para o UID: ${uid}\nAguarde até 5 minutos para aparecer no perfil!`);
    btn.disabled = false;
    btn.innerHTML = '⚡ INICIAR ENVIO AGORA';
    document.getElementById('uid').value = '';
    
    if(likesRestantes == 0){
      btn.disabled = true;
      btn.innerHTML = '⏰ Aguarde 24h';
    }
  }, 2000);
}
</script>

</body>
