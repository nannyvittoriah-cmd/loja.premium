<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Premium Vz</title>
<style>
  :root{
    --azul-fundo:#0a1a3a;
    --azul-escuro:#06122b;
    --roxo:#7c3aed;
    --azul:#2563eb;
    --dourado:#fbbf24;
    --texto:#e5e7eb;
    --cinza:#1f2937;
  }
  *{box-sizing:border-box;margin:0;padding:0;font-family:Arial,sans-serif}
  body{background:var(--azul-fundo);color:var(--texto);font-size:13px}
.header{display:flex;justify-content:space-between;align-items:center;padding:12px 16px;background:var(--azul-escuro);border-bottom:2px solid var(--roxo)}
.menu-btn{font-size:20px;background:none;border:none;color:var(--dourado);cursor:pointer}
.heart{color:var(--roxo);font-size:22px}
.container{padding:16px;max-width:1200px;margin:auto}
.top-info h2{color:var(--dourado);font-size:14px;margin-bottom:4px}
.top-info p{font-size:12px;margin-bottom:2px}
.saudacao{margin:16px 0;padding:12px;background:var(--cinza);border-left:3px solid var(--azul);border-radius:4px}
.saudacao h3{font-size:13px;color:var(--dourado)}
.saudacao p{font-size:12px;opacity:.9}
.btn-impulsionar{background:var(--cinza);color:#6b7280;border:1px solid #374151;padding:10px;width:100%;border-radius:6px;margin-bottom:20px;cursor:not-allowed}
.grid-categorias{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:12px;margin-bottom:24px}
.cat-btn{background:linear-gradient(135deg,var(--roxo),var(--azul));border:none;color:white;padding:14px 8px;border-radius:8px;cursor:pointer;font-size:12px;font-weight:bold;border:2px solid var(--dourado)}
.produtos-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:14px}
.card{background:var(--azul-escuro);border:1px solid var(--roxo);border-radius:8px;overflow:hidden}
.card img{width:100%;height:100px;object-fit:cover;background:var(--cinza)}
.card-body{padding:10px}
.card h4{font-size:12px;margin-bottom:6px;color:var(--dourado)}
.card p{font-size:11px;margin-bottom:4px}
.btn-compra{width:100%;background:var(--dourado);color:var(--azul-fundo);border:none;padding:8px;border-radius:4px;font-weight:bold;cursor:pointer;font-size:11px}
.modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:50;align-items:center;justify-content:center}
.modal.active{display:flex}
.modal-content{background:var(--azul-escuro);padding:20px;border-radius:8px;width:90%;max-width:360px;border:2px solid var(--roxo)}
.modal-content h3{color:var(--dourado);margin-bottom:12px;font-size:14px;text-align:center}
.modal-content input,.modal-content select{width:100%;padding:9px;margin-bottom:10px;background:var(--cinza);border:1px solid var(--roxo);color:var(--texto);border-radius:4px;font-size:12px}
.modal-content button{width:100%;background:var(--azul);color:white;border:none;padding:9px;border-radius:4px;cursor:pointer;font-size:12px;margin-bottom:8px}
.btn-secundario{background:var(--cinza)!important;border:1px solid var(--roxo)!important}
.btn-dourado{background:var(--dourado)!important;color:var(--azul-fundo)!important;font-weight:bold}
.admin-panel{display:none}
.admin-panel.active{display:block}
.admin-bar{background:var(--roxo);padding:8px 16px;display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.hidden{display:none}
.user-bar{display:flex;justify-content:space-between;align-items:center;background:var(--cinza);padding:8px 16px;font-size:11px;border-bottom:1px solid var(--roxo)}
.link{color:var(--dourado);cursor:pointer;text-decoration:underline;font-size:11px}
</style>
</head>
<body>

<!-- LOGIN/CADASTRO CLIENTE -->
<div id="loginCliente" class="modal active">
  <div class="modal-content">
    <h3>♥ Premium Vz ♥</h3>
    <div id="formLogin">
      <input type="text" id="clienteUser" placeholder="Usuário ou Email">
      <input type="password" id="clientePass" placeholder="Senha">
      <button class="btn-dourado" onclick="loginCliente()">Entrar</button>
      <button class="btn-secundario" onclick="mostrarCadastro()">Criar conta</button>
      <p style="text-align:center;margin-top:8px"><span class="link" onclick="abrirLoginAdmin()">Acesso Admin</span></p>
    </div>
    <div id="formCadastro" class="hidden">
      <input type="text" id="cadNome" placeholder="Nome completo">
      <input type="text" id="cadUser" placeholder="Criar usuário">
      <input type="text" id="cadWhats" placeholder="WhatsApp">
      <input type="password" id="cadPass" placeholder="Criar senha">
      <button class="btn-dourado" onclick="cadastrarCliente()">Cadastrar</button>
      <button class="btn-secundario" onclick="mostrarLogin()">Já tenho conta</button>
    </div>
  </div>
</div>

<!-- LOGIN ADMIN -->
<div id="loginAdmin" class="modal">
  <div class="modal-content">
    <h3>Painel de Admin</h3>
    <input type="text" id="adminUser" placeholder="Usuário">
    <input type="password" id="adminPass" placeholder="Senha">
    <button class="btn-dourado" onclick="fazerLoginAdmin()">Entrar como Admin</button>
    <button class="btn-secundario" onclick="voltarLoginCliente()">Voltar</button>
  </div>
</div>

<!-- APP PRINCIPAL -->
<div id="app" class="hidden">
  <div class="user-bar">
    <span id="nomeClienteLogado"></span>
    <span class="link" onclick="sair()">Sair</span>
  </div>

  <div class="header">
    <button class="menu-btn" onclick="toggleMenu()">☰</button>
    <span class="heart">♥</span>
  </div>

  <div class="container">
    <div class="top-info">
      <h2>Total de compras feitas</h2>
      <p>@chanelff__ | WhatsApp: 98984753563</p>
    </div>

    <div class="saudacao">
      <h3 id="saudacaoCliente">Oie, cliente!</h3>
      <p>Seu painel está otimizado</p>
    </div>

    <button class="btn-impulsionar" disabled>Impulsionar</button>

    <div id="categoriasView">
      <div class="grid-categorias" id="gridCategorias"></div>
    </div>

    <div id="produtosView" class="hidden">
      <button onclick="voltarCategorias()" style="margin-bottom:12px;background:var(--cinza);border:1px solid var(--roxo);color:var(--texto);padding:6px 10px;border-radius:4px;cursor:pointer;font-size:11px">← Voltar</button>
      <h3 id="tituloCat" style="color:var(--dourado);font-size:13px;margin-bottom:12px"></h3>
      <div class="produtos-grid" id="gridProdutos"></div>
    </div>

    <div id="adminPanel" class="admin-panel">
      <div class="admin-bar">
        <span style="font-size:12px;font-weight:bold">PAINEL ADMIN</span>
        <button onclick="abrirModalProduto()" style="background:var(--dourado);color:var(--azul-fundo);border:none;padding:6px 10px;border-radius:4px;font-size:11px;cursor:pointer">+ Adicionar</button>
      </div>
    </div>
  </div>
</div>

<!-- MODAL PRODUTO -->
<div id="modalProduto" class="modal">
  <div class="modal-content">
    <h3 id="modalTitulo">Adicionar Produto</h3>
    <select id="pCategoria"></select>
    <input type="text" id="pNome" placeholder="Nome do produto">
    <input type="text" id="pImagem" placeholder="URL da imagem">
    <input type="number" id="pValor" placeholder="Valor R$">
    <input type="number" id="pEstoque" placeholder="Estoque">
    <button class="btn-dourado" onclick="salvarProduto()">Salvar</button>
    <button class="btn-secundario" onclick="fecharModalProduto()">Fechar</button>
  </div>
</div>

<script>
  const CATEGORIAS = [
    'Categorias FF',
    'Categorias Instagram',
    'Categorias TikTok',
    'Categorias Kwai',
    'Categorias Curso',
    'Categoria Caixa Surpresa'
  ];

  let db = JSON.parse(localStorage.getItem('premiumvz')) || {
    produtos: [],
    clientes: [],
    clienteLogado: null,
    adminLogado: false
  };

  let categoriaAtual = null;
  let editandoId = null;

  // CLIENTE
  function mostrarCadastro(){
    document.getElementById('formLogin').classList.add('hidden');
    document.getElementById('formCadastro').classList.remove('hidden');
  }

  function mostrarLogin(){
    document.getElementById('formCadastro').classList.add('hidden');
    document.getElementById('formLogin').classList.remove('hidden');
  }

  function cadastrarCliente(){
    const nome = document.getElementById('cadNome').value.trim();
    const user = document.getElementById('cadUser').value.trim();
    const whats = document.getElementById('cadWhats').value.trim();
    const pass = document.getElementById('cadPass').value.trim();

    if(!nome ||!user ||!pass){
      alert('Preencha nome, usuário e senha');
      return;
    }
    if(db.clientes.find(c => c.user === user)){
      alert('Usuário já existe');
      return;
    }

    db.clientes.push({nome, user, whats, pass});
    salvarDB();
    alert('Cadastro feito! Faça login');
    mostrarLogin();
  }

  function loginCliente(){
    const user = document.getElementById('clienteUser').value.trim();
    const pass = document.getElementById('clientePass').value.trim();
    const cliente = db.clientes.find(c => c.user === user && c.pass === pass);

    if(cliente){
      db.clienteLogado = cliente;
      db.adminLogado = false;
      salvarDB();
      entrarSite();
    } else {
      alert('Usuário ou senha incorretos');
    }
  }

  // ADMIN
  function abrirLoginAdmin(){
    document.getElementById('loginCliente').classList.remove('active');
    document.getElementById('loginAdmin').classList.add('active');
  }

  function voltarLoginCliente(){
    document.getElementById('loginAdmin').classList.remove('active');
    document.getElementById('loginCliente').classList.add('active');
  }

  function fazerLoginAdmin(){
    const u = document.getElementById('adminUser').value;
    const p = document.getElementById('adminPass').value;
    if(u==='Lorrannyh.16' && p==='Lorrannyh.16'){
      db.adminLogado = true;
      db.clienteLogado = {nome: 'Admin', user: 'Lorrannyh.16'};
      salvarDB();
      document.getElementById('loginAdmin').classList.remove('active');
      entrarSite();
    } else {
      alert('Acesso negado');
    }
  }

  function entrarSite(){
    document.getElementById('loginCliente').classList.remove('active');
    document.getElementById('loginAdmin').classList.remove('active');
    document.getElementById('app').classList.remove('hidden');

    if(db.adminLogado){
      document.getElementById('adminPanel').classList.add('active');
      document.getElementById('saudacaoCliente').textContent = 'Oie, Admin!';
    } else {
      document.getElementById('adminPanel').classList.remove('active');
      document.getElementById('saudacaoCliente').textContent = `Oie, ${db.clienteLogado.nome}!`;
    }

    document.getElementById('nomeClienteLogado').textContent = `Logado: ${db.clienteLogado.user}`;
    init();
  }

  function sair(){
    db.clienteLogado = null;
    db.adminLogado = false;
    salvarDB();
    location.reload();
  }

  // SITE
  function init(){
    renderCategorias();
    popularSelectCategoria();
  }

  function renderCategorias(){
    const grid = document.getElementById('gridCategorias');
    grid.innerHTML = CATEGORIAS.map(cat =>
      `<button class="cat-btn" onclick="abrirCategoria('${cat}')">${cat}</button>`
    ).join('');
  }

  function abrirCategoria(cat){
    categoriaAtual = cat;
    document.getElementById('categoriasView').classList.add('hidden');
    document.getElementById('produtosView').classList.remove('hidden');
    document.getElementById('tituloCat').textContent = cat;
    renderProdutos();
  }

  function voltarCategorias(){
    document.getElementById('categoriasView').classList.remove('hidden');
    document.getElementById('produtosView').classList.add('hidden');
    categoriaAtual = null;
  }

  function renderProdutos(){
    const grid = document.getElementById('gridProdutos');
    const lista = db.produtos.filter(p => p.categoria === categoriaAtual);
    if(lista.length === 0){
      grid.innerHTML = '<p style="grid-column:1/-1;text-align:center;opacity:.6;font-size:11px">Nenhum produto cadastrado</p>';
      return;
    }
    grid.innerHTML = lista.map(p => `
      <div class="card">
        <img src="${p.imagem || 'https://via.placeholder.com/160x100/1f2937/7c3aed?text=Premium+Vz'}" alt="">
        <div class="card-body">
          <h4>${p.nome}</h4>
          <p>R$ ${p.valor.toFixed(2)}</p>
          <p>Estoque: ${p.estoque}</p>
          <button class="btn-compra" onclick="comprar(${p.id})">Comprar</button>
          ${db.adminLogado? `<button style="width:100%;margin-top:4px;background:var(--roxo);color:white;border:none;padding:6px;border-radius:4px;font-size:10px;cursor:pointer" onclick="editarProduto(${p.id})">Editar</button>` : ''}
        </div>
      </div>
    `).join('');
  }

  function comprar(id){
    const produto = db.produtos.find(p => p.id === id);
    const msg = `Olá! Quero comprar: ${produto.nome} - R$${produto.valor.toFixed(2)}`;
    window.open(`https://wa.me/5598984753563?text=${encodeURIComponent(msg)}`, '_blank');
  }

  function abrirModalProduto(){
    editandoId = null;
    document.getElementById('modalTitulo').textContent = 'Adicionar Produto';
    document.getElementById('pNome').value = '';
    document.getElementById('pImagem').value = '';
    document.getElementById('pValor').value = '';
    document.getElementById('pEstoque').value = '';
    document.getElementById('modalProduto').classList.add('active');
  }

  function editarProduto(id){
    const p = db.produtos.find(prod => prod.id === id);
    editandoId = id;
    document.getElementById('modalTitulo').textContent = 'Editar Produto';
    document.getElementById('pCategoria').value = p.categoria;
    document.getElementById('pNome').value = p.nome;
    document.getElementById('pImagem').value = p.imagem;
    document.getElementById('pValor').value = p.valor;
    document.getElementById('pEstoque').value = p.estoque;
    document.getElementById('modalProduto').classList.add('active');
  }

  function fecharModalProduto(){
    document.getElementById('modalProduto').classList.remove('active');
  }

  function popularSelectCategoria(){
    document.getElementById('pCategoria').innerHTML = CATEGORIAS.map(c =>
      `<option value="${c}">${c}</option>`
    ).join('');
  }

  function salvarProduto(){
    const produto = {
      id: editandoId || Date.now(),
      categoria: document.getElementById('pCategoria').value,
      nome: document.getElementById('pNome').value,
      imagem: document.getElementById('pImagem').value,
      valor: parseFloat(document.getElementById('pValor').value) || 0,
      estoque: parseInt(document.getElementById('pEstoque').value) || 0
    };

    if(editandoId){
      const idx = db.produtos.findIndex(p => p.id === editandoId);
      db.produtos[idx] = produto;
    } else {
      db.produtos.push(produto);
    }

    salvarDB();
    fecharModalProduto();
    if(categoriaAtual) renderProdutos();
  }

  function toggleMenu(){
    alert('Menu: Fechar | Categorias | Redes sociais | Painel Admin');
  }

  function salvarDB(){
    localStorage.setItem('premiumvz', JSON.stringify(db));
  }

  // Auto login se já tiver sessão
  if(db.clienteLogado || db.adminLogado){
    entrarSite();
  }
</script>
</body>
</html>