<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BS Store</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial}

body{background:#0b0f2a;color:#fff;}
body.light{background:#fff;color:#000;}

.topo{
display:flex;justify-content:space-between;
padding:15px;border-bottom:2px solid #ff008c;
}

.logo{color:#ff008c;font-size:22px;font-weight:bold;}
.menu{font-size:22px;cursor:pointer;}

.container{padding:20px;}

.grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:15px;margin-top:20px;
}

.card{
background:#11163a;padding:15px;
border-radius:10px;text-align:center;
cursor:pointer;
}

button{
margin-top:10px;padding:10px;
background:#ff008c;border:none;color:#fff;border-radius:5px;width:100%;
}

input{
width:100%;
margin-top:8px;
padding:10px;
border:none;
border-radius:5px;
}

/* painel */
.painel{
display:none;
background:#11163a;
padding:10px;
margin-top:20px;
border-radius:10px;
}

.produto{
background:#1e244f;
padding:10px;
border-radius:10px;
margin-top:10px;
}
</style>
</head>

<body>

<div class="topo">
<div class="logo">BS</div>
<div class="menu" onclick="painel.style.display=painel.style.display=='block'?'none':'block'">⚙️</div>
</div>

<div class="container">

<h2 id="titulo">Categorias</h2>

<button onclick="voltar()" id="voltarBtn" style="display:none">⬅ Voltar</button>

<div class="grid" id="lista"></div>

<!-- 🔥 PAINEL -->
<div id="painel" class="painel">

<h3>ADMIN</h3>

<input id="nome" placeholder="Nome">
<input id="img" placeholder="Imagem">
<input id="preco" placeholder="Preço">
<input id="desc" placeholder="Descrição">

<button onclick="salvar()">Salvar</button>

<div id="adminLista"></div>

</div>

</div>

<script>

let loja = JSON.parse(localStorage.getItem("loja")) || {
categorias:[
{nome:"Instagram",img:"https://cdn-icons-png.flaticon.com/512/2111/2111463.png",produtos:[]}
]
};

let modo="categoria";
let atual=null;
let editIndex=null;

/* RENDER */
function render(){
let html="";

if(modo==="categoria"){
titulo.innerText="Categorias";
voltarBtn.style.display="none";

loja.categorias.forEach((c,i)=>{
html+=`
<div class="card" onclick="abrirCategoria(${i})">
<img src="${c.img}" width="50"><br>
${c.nome}
</div>`;
});
}

if(modo==="produto"){
titulo.innerText=loja.categorias[atual].nome;
voltarBtn.style.display="block";

loja.categorias[atual].produtos.forEach((p,i)=>{
html+=`
<div class="produto">
<img src="${p.img}" width="50"><br>
<b>${p.nome}</b><br>
${p.preco}<br>
<small>${p.desc}</small>

<button onclick="editar(${i})">Editar</button>
<button onclick="del(${i})">Excluir</button>
</div>`;
});
}

lista.innerHTML=html;
renderAdmin();
}

/* ABRIR */
function abrirCategoria(i){
modo="produto";
atual=i;
render();
}

function voltar(){
modo="categoria";
render();
}

/* SALVAR */
function salvar(){

if(modo==="categoria"){
loja.categorias.push({
nome:nome.value,
img:img.value,
produtos:[]
});
}

if(modo==="produto"){
if(editIndex===null){
loja.categorias[atual].produtos.push({
nome:nome.value,
img:img.value,
preco:preco.value,
desc:desc.value
});
}else{
let p=loja.categorias[atual].produtos[editIndex];
p.nome=nome.value;
p.img=img.value;
p.preco=preco.value;
p.desc=desc.value;
editIndex=null;
}
}

limpar();
save();
}

/* EDITAR */
function editar(i){
let p=loja.categorias[atual].produtos[i];

nome.value=p.nome;
img.value=p.img;
preco.value=p.preco;
desc.value=p.desc;

editIndex=i;
}

/* DELETAR */
function del(i){
loja.categorias[atual].produtos.splice(i,1);
save();
}

/* ADMIN LISTA */
function renderAdmin(){
let html="";

if(modo==="categoria"){
loja.categorias.forEach((c,i)=>{
html+=`
<div>
${c.nome}
<button onclick="remCat(${i})">❌</button>
</div>`;
});
}

adminLista.innerHTML=html;
}

/* REMOVER CAT */
function remCat(i){
loja.categorias.splice(i,1);
save();
}

/* SAVE */
function save(){
localStorage.setItem("loja",JSON.stringify(loja));
render();
}

/* LIMPAR */
function limpar(){
nome.value="";
img.value="";
preco.value="";
desc.value="";
}

/* INIT */
render();

</script>

</body>
</html>