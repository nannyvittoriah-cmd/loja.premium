<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BS Store</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial}

body{background:#0b0f2a;color:#fff;}
body.light{background:#ffffff;color:#000;}

.topo{
display:flex;justify-content:space-between;
padding:15px;border-bottom:2px solid #ff008c;
position:relative;
}

.logo{color:#ff008c;font-size:22px;font-weight:bold;}
.menu{font-size:22px;cursor:pointer;}

.dropdown{
position:absolute;right:10px;top:60px;
background:#11163a;border:1px solid #ff008c;
border-radius:10px;display:none;
z-index:999;
}

.dropdown div{padding:12px;cursor:pointer;}
.dropdown div:hover{background:#ff008c;}

.container{padding:20px;}

.grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:15px;margin-top:20px;
}

.card{
background:#11163a;padding:15px;
border-radius:10px;text-align:center;
}

body.light .card{background:#eee;}

.modal{
position:fixed;inset:0;
background:rgba(0,0,0,0.6);
display:none;justify-content:center;align-items:center;
z-index:9999;
}

.box{
background:#11163a;padding:20px;
border-radius:10px;width:260px;position:relative;
}

body.light .box{background:#fff;color:#000;}

.fechar{position:absolute;top:10px;right:10px;cursor:pointer;}

input{
width:100%;
margin-top:8px;
padding:10px;
border:none;
border-radius:5px;
}

button{
width:100%;
margin-top:10px;
padding:10px;
background:#ff008c;
border:none;
color:#fff;
border-radius:5px;
}

/* 🔥 NOVO PAINEL */
.lista-admin{
margin-top:15px;
background:#0f1435;
padding:10px;
border-radius:10px;
}

.item-admin{
display:flex;
justify-content:space-between;
align-items:center;
margin:5px 0;
background:#1e244f;
padding:8px;
border-radius:6px;
}
</style>
</head>

<body>

<div class="topo">
<div class="logo">BS</div>

<div class="menu" onclick="toggleMenu()">⋮</div>

<div class="dropdown" id="menu">
<div onclick="abrirAfiliado()">Afiliados</div>
<div onclick="trocarTema()">Tema</div>
<div onclick="abrirLogin()">Painel ADM</div>
</div>
</div>

<div class="container">

<h2>Bem-vindo à BS Store</h2>

<div class="grid" id="lista"></div>

<!-- 🔥 PAINEL ADM COMPLETO -->
<div id="painel" style="display:none">

<h3>Painel ADM</h3>

<input id="nome" placeholder="Nome categoria">
<input id="img" placeholder="URL imagem">

<button id="btnAdd" onclick="salvarCategoria()">Adicionar</button>
<button onclick="cancelar()" id="cancelarBtn" style="display:none;background:#555">Cancelar</button>

<div class="lista-admin" id="listaAdmin"></div>

</div>

</div>

<!-- LOGIN -->
<div class="modal" id="login">
<div class="box">
<div class="fechar" onclick="fecharTudo()">✖</div>

<h3>Login ADM</h3>
<input id="email" placeholder="Email">
<input id="senha" type="password" placeholder="Senha">
<button onclick="logar()">Entrar</button>
</div>
</div>

<!-- AFILIADO -->
<div class="modal" id="afiliado">
<div class="box">
<div class="fechar" onclick="fecharTudo()">✖</div>

<h3>Programa de Afiliados</h3>

<input id="nomeAfiliado" placeholder="Seu nome">
<input id="telefoneAfiliado" placeholder="Seu telefone">

<button onclick="participar()">Participar</button>
</div>
</div>

<script>

let dados = JSON.parse(localStorage.getItem("cats")) || [
{nome:"Instagram",img:"https://cdn-icons-png.flaticon.com/512/2111/2111463.png"},
{nome:"TikTok",img:"https://cdn-icons-png.flaticon.com/512/3046/3046121.png"}
];

let admin=false;
let editIndex=null;

/* RENDER LOJA */
function render(){
let area=document.getElementById("lista");
area.innerHTML="";
dados.forEach(c=>{
area.innerHTML+=`
<div class="card">
<img src="${c.img}" width="50"><br>
${c.nome}
</div>`;
});
}

/* RENDER ADMIN */
function renderAdmin(){
let area=document.getElementById("listaAdmin");
area.innerHTML="";

dados.forEach((c,i)=>{
area.innerHTML+=`
<div class="item-admin">
<span>${c.nome}</span>

<div>
<button onclick="editar(${i})">✏️</button>
<button onclick="remover(${i})">❌</button>
</div>

</div>`;
});
}

/* ADD / EDIT */
function salvarCategoria(){

let nome=document.getElementById("nome").value;
let img=document.getElementById("img").value;

if(!nome || !img) return alert("Preencha tudo");

if(editIndex===null){
dados.push({nome,img});
}else{
dados[editIndex]={nome,img};
editIndex=null;
document.getElementById("btnAdd").innerText="Adicionar";
document.getElementById("cancelarBtn").style.display="none";
}

limpar();
salvar();
}

/* EDITAR */
function editar(i){
editIndex=i;

nome.value=dados[i].nome;
img.value=dados[i].img;

btnAdd.innerText="Atualizar";
cancelarBtn.style.display="block";
}

/* CANCELAR */
function cancelar(){
editIndex=null;
limpar();
btnAdd.innerText="Adicionar";
cancelarBtn.style.display="none";
}

/* REMOVER */
function remover(i){
if(confirm("Excluir?")){
dados.splice(i,1);
salvar();
}
}

/* SALVAR */
function salvar(){
localStorage.setItem("cats",JSON.stringify(dados));
render();
renderAdmin();
}

/* LIMPAR */
function limpar(){
nome.value="";
img.value="";
}

/* LOGIN */
function abrirLogin(){
login.style.display="flex";
}

function logar(){
if(email.value==="nannyvittoriah@gmail.com" && senha.value==="Lorrannyh.170"){
admin=true;
login.style.display="none";
painel.style.display="block";
renderAdmin();
}else alert("Erro");
}

/* MENU */
function toggleMenu(){
menu.style.display=menu.style.display=="block"?"none":"block";
}

function fecharTudo(){
menu.style.display="none";
login.style.display="none";
afiliado.style.display="none";
}

/* AFILIADO */
function abrirAfiliado(){
afiliado.style.display="flex";
}

function participar(){
let numero="5598984853563";
let link="https://wa.me/"+numero;
window.open(link,"_blank");
}

/* TEMA */
function trocarTema(){
document.body.classList.toggle("light");
}

render();

</script>

</body>
</html>