<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Painel Curtidas FF</title>

<style>
body{
    margin:0;
    font-family:Arial;
    background:#0f172a;
    color:white;
}

.topo{
    background:#1e293b;
    padding:15px;
    display:flex;
    justify-content:space-between;
}

.container{
    padding:15px;
}

.card{
    background:#1e293b;
    padding:15px;
    margin-bottom:10px;
    border-radius:10px;
}

button{
    background:#ec4899;
    border:none;
    padding:10px;
    color:white;
    border-radius:8px;
    cursor:pointer;
}

input, select{
    width:100%;
    padding:8px;
    margin-top:5px;
    margin-bottom:10px;
    border-radius:5px;
    border:none;
}

.hidden{display:none;}
</style>
</head>

<body>

<div class="topo">
    <b>Painel FF</b>
    <div>
        Saldo: <span id="saldo">0</span>
    </div>
</div>

<div class="container">

<!-- LOGIN -->
<div id="loginBox" class="card">
    <h3>Login / Cadastro</h3>
    <input id="user" placeholder="Usuário">
    <button onclick="login()">Entrar</button>
</div>

<!-- PAINEL -->
<div id="painel" class="hidden">

<div class="card">
    <h3>Enviar Curtidas</h3>
    <input id="ffid" placeholder="ID Free Fire">
    
    <select id="servico"></select>
    
    <button onclick="enviar()">Enviar</button>
</div>

<div class="card">
    <h3>Pedidos</h3>
    <div id="pedidos"></div>
</div>

<div class="card">
    <h3>Ganhar moedas</h3>
    <button onclick="ganhar()">Ganhar +10</button>
</div>

<div class="card">
    <h3>Admin</h3>

    <input id="catNome" placeholder="Nova categoria">
    <button onclick="addCategoria()">Adicionar Categoria</button>

    <hr>

    <input id="servNome" placeholder="Nome do serviço">
    <input id="servDesc" placeholder="Descrição">
    <input id="servPreco" placeholder="Preço">
    
    <select id="catSelect"></select>

    <button onclick="addServico()">Adicionar Serviço</button>

</div>

</div>

</div>

<script>

let usuario = null;

let dados = JSON.parse(localStorage.getItem("dados")) || {
    users:{},
    categorias:[],
    servicos:[]
};

function salvar(){
    localStorage.setItem("dados", JSON.stringify(dados));
}

function login(){
    let u = user.value;
    if(!dados.users[u]){
        dados.users[u] = {saldo:100, pedidos:[]};
    }
    usuario = u;
    salvar();
    iniciar();
}

function iniciar(){
    loginBox.classList.add("hidden");
    painel.classList.remove("hidden");
    atualizar();
}

function atualizar(){
    saldo.innerText = dados.users[usuario].saldo;

    // serviços
    servico.innerHTML="";
    catSelect.innerHTML="";

    dados.categorias.forEach((c,i)=>{
        let op = document.createElement("option");
        op.value=i;
        op.textContent=c;
        catSelect.appendChild(op);
    });

    dados.servicos.forEach((s,i)=>{
        let op = document.createElement("option");
        op.value=i;
        op.textContent = `${s.nome} (${s.preco})`;
        servico.appendChild(op);
    });

    // pedidos
    pedidos.innerHTML="";
    dados.users[usuario].pedidos.forEach(p=>{
        let div = document.createElement("div");
        div.innerText = p;
        pedidos.appendChild(div);
    });
}

function ganhar(){
    dados.users[usuario].saldo += 10;
    salvar();
    atualizar();
}

function enviar(){
    let s = dados.servicos[servico.value];
    let userData = dados.users[usuario];

    if(!s) return;

    if(userData.saldo < s.preco){
        alert("Saldo insuficiente");
        return;
    }

    userData.saldo -= s.preco;

    let texto = `⏳ Enviando ${s.nome} para ID ${ffid.value}`;
    userData.pedidos.push(texto);

    salvar();
    atualizar();

    setTimeout(()=>{
        userData.pedidos.push(`✔ ${s.nome} entregue`);
        salvar();
        atualizar();
    },3000);
}

function addCategoria(){
    let nome = catNome.value;
    if(!nome) return;

    dados.categorias.push(nome);
    salvar();
    atualizar();
}

function addServico(){
    let nome = servNome.value;
    let desc = servDesc.value;
    let preco = parseInt(servPreco.value);
    let cat = catSelect.value;

    dados.servicos.push({
        nome,
        desc,
        preco,
        categoria:cat
    });

    salvar();
    atualizar();
}

</script>

</body>
</html>