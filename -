<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BS Store</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial}

body{background:#0b0f2a;color:#fff;}
body.light{background:#fff;color:#000;}

.topo{
display:flex;justify-content:space-between;
padding:15px;border-bottom:2px solid #ff008c;
}

.logo{color:#ff008c;font-size:22px;font-weight:bold;}
.menu{font-size:22px;cursor:pointer;}

.dropdown{
position:absolute;right:10px;top:60px;
background:#11163a;border:1px solid #ff008c;
border-radius:10px;display:none;
}

.dropdown div{padding:12px;cursor:pointer;}
.dropdown div:hover{background:#ff008c;}

.container{padding:20px;}

.grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:15px;margin-top:20px;
}

.card{
background:#11163a;padding:15px;
border-radius:10px;text-align:center;
}

input,select{
width:100%;margin-top:8px;padding:10px;
border:none;border-radius:5px;
}

button{
width:100%;margin-top:10px;padding:10px;
background:#ff008c;border:none;color:#fff;border-radius:5px;
}

.painel-box{
background:#11163a;
padding:10px;
border-radius:10px;
margin-top:10px;
}
</style>
</head>

<body>

<div class="topo">
<div class="logo">BS</div>

<div class="menu" onclick="menu.style.display=menu.style.display=='block'?'none':'block'">⋮</div>

<div class="dropdown" id="menu">
<div onclick="abrirLogin()">Painel ADM</div>
</div>
</div>

<div class="container">

<h2>BS Store</h2>
<div id="lista" class="grid"></div>

<div id="painel" style="display:none">

<h3>ADMIN COMPLETO</h3>

<div class="painel-box">
<h4>Categoria</h4>
<input id="catNome" placeholder="Nome">
<button onclick="addCategoria()">Criar</button>
</div>

<div class="painel-box">
<h4>Subcategoria</h4>
<select id="catSelect"></select>
<input id="subNome" placeholder="Nome sub">
<button onclick="addSub()">Criar</button>
</div>

<div class="painel-box">
<h4>Produto</h4>
<select id="catSelect2"></select>
<select id="subSelect"></select>

<input id="prodNome" placeholder="Nome">
<input id="prodPreco" placeholder="Preço">
<input id="prodDesc" placeholder="Descrição">
<input id="prodImg" placeholder="Imagem URL">

<button onclick="addProduto()">Adicionar</button>
</div>

<div class="painel-box" id="adminLista"></div>

</div>

</div>

<div id="login" style="display:none">
<input id="email">
<input id="senha">
<button onclick="logar()">Entrar</button>
</div>

<script>

let loja = JSON.parse(localStorage.getItem("loja")) || {categorias:[]};

/* LOGIN */
function abrirLogin(){
login.style.display="block";
}

function logar(){
if(email.value==="nannyvittoriah@gmail.com" && senha.value==="Lorrannyh.170"){
painel.style.display="block";
login.style.display="none";
renderSelects();
renderAdmin();
}else alert("Erro");
}

/* CATEGORIA */
function addCategoria(){
loja.categorias.push({nome:catNome.value,subs:[]});
salvar();
}

/* SUB */
function addSub(){
let c = catSelect.value;
loja.categorias[c].subs.push({nome:subNome.value,produtos:[]});
salvar();
}

/* PRODUTO */
function addProduto(){
let c = catSelect2.value;
let s = subSelect.value;

loja.categorias[c].subs[s].produtos.push({
nome:prodNome.value,
preco:prodPreco.value,
desc:prodDesc.value,
img:prodImg.value
});

salvar();
}

/* RENDER */
function render(){
let html="";
loja.categorias.forEach(c=>{
html+=`<div>${c.nome}</div>`;
});
lista.innerHTML=html;
}

function renderSelects(){
catSelect.innerHTML="";
catSelect2.innerHTML="";

loja.categorias.forEach((c,i)=>{
catSelect.innerHTML+=`<option value="${i}">${c.nome}</option>`;
catSelect2.innerHTML+=`<option value="${i}">${c.nome}</option>`;
});
updateSub();
}

function updateSub(){
let c=catSelect2.value;
subSelect.innerHTML="";
if(!loja.categorias[c]) return;

loja.categorias[c].subs.forEach((s,i)=>{
subSelect.innerHTML+=`<option value="${i}">${s.nome}</option>`;
});
}

catSelect2.onchange=updateSub;

/* ADMIN LISTA */
function renderAdmin(){
let html="";
loja.categorias.forEach((c,ci)=>{
html+=`<h4>${c.nome}</h4>`;

c.subs.forEach((s,si)=>{
html+=`<div>${s.nome}</div>`;

s.produtos.forEach((p,pi)=>{
html+=`
<div>
${p.nome} - ${p.preco}
<button onclick="editar(${ci},${si},${pi})">✏️</button>
<button onclick="delProd(${ci},${si},${pi})">❌</button>
</div>`;
});
});
});
adminLista.innerHTML=html;
}

function editar(c,s,p){
let prod=loja.categorias[c].subs[s].produtos[p];

prod.nome=prompt("Nome",prod.nome);
prod.preco=prompt("Preço",prod.preco);
prod.desc=prompt("Desc",prod.desc);
prod.img=prompt("Img",prod.img);

salvar();
}

function delProd(c,s,p){
loja.categorias[c].subs[s].produtos.splice(p,1);
salvar();
}

/* SALVAR */
function salvar(){
localStorage.setItem("loja",JSON.stringify(loja));
render();
renderSelects();
renderAdmin();
}

render();

</script>

</body>
</html>