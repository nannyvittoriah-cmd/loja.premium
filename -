<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BS Store</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial}

body{background:#0b0f2a;color:#fff;}
body.light{background:#ffffff;color:#000;}

.topo{
display:flex;
justify-content:space-between;
padding:15px;
border-bottom:2px solid #ff008c;
}

.logo{color:#ff008c;font-size:22px;font-weight:bold;}
.menu{font-size:22px;cursor:pointer;}

.dropdown{
position:absolute;
right:10px;
top:60px;
background:#11163a;
border:1px solid #ff008c;
border-radius:10px;
display:none;
}

.dropdown div{padding:12px;cursor:pointer;}
.dropdown div:hover{background:#ff008c;}

.container{padding:20px;}

.grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:15px;
margin-top:20px;
}

.card{
background:#11163a;
padding:15px;
border-radius:10px;
text-align:center;
}

body.light .card{background:#eee;}

.admin-btns{display:none;margin-top:5px;}
.admin .admin-btns{display:block;}

.modal{
position:fixed;
inset:0;
background:rgba(0,0,0,0.6);
display:none;
justify-content:center;
align-items:center;
}

.box{
background:#11163a;
padding:20px;
border-radius:10px;
width:260px;
position:relative;
}

.fechar{
position:absolute;
top:10px;
right:10px;
cursor:pointer;
}

input{
width:100%;
margin-top:8px;
padding:10px;
border:none;
border-radius:5px;
}

button{
width:100%;
margin-top:10px;
padding:10px;
background:#ff008c;
border:none;
color:#fff;
border-radius:5px;
}

/* 🔥 PAINEL */
.painel-box{
background:#1e244f;
padding:10px;
margin-top:10px;
border-radius:10px;
}
</style>
</head>

<body>

<div class="topo">
<div class="logo">BS</div>

<div class="menu" onclick="toggleMenu()">⋮</div>

<div class="dropdown" id="menu">
<div onclick="abrirAfiliado()">Afiliados</div>
<div onclick="trocarTema()">Tema</div>
<div onclick="abrirLogin()">Painel ADM</div>
</div>
</div>

<div class="container">

<h2>Bem-vindo à BS Store</h2>

<div class="grid" id="lista"></div>

<!-- 🔥 PAINEL NOVO -->
<div id="painel" style="display:none">

<h3>Painel ADM COMPLETO</h3>

<div class="painel-box">
<h4>Editar Categoria</h4>

<input id="nome" placeholder="Nome">
<input id="img" placeholder="Imagem URL">
<input id="valor" placeholder="Valor (novo)">
<input id="desc" placeholder="Descrição (novo)">

<button onclick="salvarCategoria()">Salvar</button>
</div>

<div class="painel-box" id="listaAdmin"></div>

</div>

</div>

<!-- LOGIN -->
<div class="modal" id="login">
<div class="box">
<div class="fechar" onclick="fecharTudo()">✖</div>

<h3>Login ADM</h3>
<input id="email">
<input id="senha" type="password">
<button onclick="logar()">Entrar</button>
</div>
</div>

<script>

/* 🔥 NOVO BANCO (SEM QUEBRAR) */
let dados = JSON.parse(localStorage.getItem("cats")) || [
{nome:"Instagram",img:"https://cdn-icons-png.flaticon.com/512/2111/2111463.png",valor:"",desc:""},
{nome:"TikTok",img:"https://cdn-icons-png.flaticon.com/512/3046/3046121.png",valor:"",desc:""}
];

let editIndex=null;

/* RENDER LOJA (NÃO ALTEREI) */
function render(){
let area=document.getElementById("lista");
area.innerHTML="";
dados.forEach(c=>{
area.innerHTML+=`
<div class="card">
<img src="${c.img}" width="50"><br>
${c.nome}
</div>`;
});
}

/* RENDER ADMIN */
function renderAdmin(){
let html="";
dados.forEach((c,i)=>{
html+=`
<div class="painel-box">
<b>${c.nome}</b><br>
<small>Valor: ${c.valor || "—"}</small><br>
<small>Desc: ${c.desc || "—"}</small><br>

<button onclick="editar(${i})">Editar</button>
<button onclick="remover(${i})">Excluir</button>
</div>`;
});
listaAdmin.innerHTML=html;
}

/* EDITAR */
function editar(i){
editIndex=i;

nome.value=dados[i].nome;
img.value=dados[i].img;
valor.value=dados[i].valor;
desc.value=dados[i].desc;
}

/* SALVAR */
function salvarCategoria(){

if(editIndex===null){
dados.push({
nome:nome.value,
img:img.value,
valor:valor.value,
desc:desc.value
});
}else{
dados[editIndex]={
nome:nome.value,
img:img.value,
valor:valor.value,
desc:desc.value
};
editIndex=null;
}

limpar();
salvar();
}

/* REMOVER */
function remover(i){
if(confirm("Excluir?")){
dados.splice(i,1);
salvar();
}
}

/* SALVAR STORAGE */
function salvar(){
localStorage.setItem("cats",JSON.stringify(dados));
render();
renderAdmin();
}

/* LIMPAR */
function limpar(){
nome.value="";
img.value="";
valor.value="";
desc.value="";
}

/* LOGIN */
function abrirLogin(){
login.style.display="flex";
}

function logar(){
if(email.value==="nannyvittoriah@gmail.com" && senha.value==="Lorrannyh.170"){
login.style.display="none";
painel.style.display="block";
renderAdmin();
}else alert("Erro");
}

/* MENU */
function toggleMenu(){
menu.style.display=menu.style.display=="block"?"none":"block";
}

function fecharTudo(){
menu.style.display="none";
login.style.display="none";
}

/* TEMA */
function trocarTema(){
document.body.classList.toggle("light");
}

render();

</script>

</body>
</html>