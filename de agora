<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium Store</title>
    <style>
        :root {
            --primary: #ff007f;
            --primary-hover: #e6006f;
            --card-bg: #1a0d1a;
            --bg: #0a0a0a;
            --card-border: #2a1a2a;
        }
        
        .theme-blue {
            --primary: #0088ff;
            --primary-hover: #0077ee;
            --card-bg: #0d1a2a;
            --card-border: #1a2a3a;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        html {
            scroll-behavior: smooth;
        }
        
        body {
            background-color: var(--bg);
            color: #fff;
            font-family: 'Segoe UI', Arial, sans-serif;
            min-height: 100vh;
            font-size: 14px;
        }
        
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 16px;
            border-bottom: 2px solid var(--primary);
            position: sticky;
            top: 0;
            background: var(--bg);
            z-index: 100;
        }
        
        .logo {
            color: var(--primary);
            font-size: 20px;
            font-weight: bold;
        }
        
        .header-buttons {
            display: flex;
            gap: 8px;
        }
        
        .btn {
            background: var(--primary);
            color: #fff;
            border: none;
            padding: 8px 14px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            font-size: 13px;
            transition: 0.3s;
        }
        
        .btn:hover {
            background: var(--primary-hover);
        }
        
        .btn-outline {
            background: transparent;
            border: 2px solid var(--primary);
            color: var(--primary);
            padding: 6px 12px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            font-size: 13px;
            transition: 0.3s;
        }
        
        .btn-outline:hover {
            background: var(--primary);
            color: #000;
        }
        
        .btn-small {
            padding: 4px 8px;
            font-size: 12px;
        }
        
        .btn-danger {
            background: #ff3333;
        }
        
        .btn-danger:hover {
            background: #dd2222;
        }
        
        main {
            max-width: 800px;
            margin: 32px auto;
            padding: 0 16px;
        }
        
        .page {
            display: none;
        }
        
        .page.active {
            display: block;
        }
        
        .hero {
            text-align: center;
            margin-bottom: 40px;
        }
        
        h1 {
            color: var(--primary);
            font-size: 28px;
            margin-bottom: 10px;
        }
        
        .subtitle {
            color: #bbb;
            font-size: 15px;
            margin-bottom: 28px;
        }
        
        .card {
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 10px;
            padding: 20px;
            text-align: left;
            margin-bottom: 28px;
        }
        
        .card h2 {
            color: var(--primary);
            font-size: 17px;
            margin-bottom: 14px;
        }
        
        .card ol {
            padding-left: 18px;
            line-height: 1.7;
            font-size: 13px;
        }
        
        .card li {
            margin-bottom: 10px;
            color: #ddd;
        }
        
        .card a {
            color: #0088ff;
            text-decoration: none;
            font-weight: bold;
        }
        
        .security-box {
            border: 2px dashed #00ff88;
            border-radius: 6px;
            padding: 14px;
            margin-top: 18px;
            text-align: center;
        }
        
        .security-box h3 {
            color: #00ff88;
            margin-bottom: 6px;
            font-size: 14px;
        }
        
        .security-box p {
            color: #ccc;
            font-size: 12px;
        }
        
        .btn-primary {
            background: var(--primary);
            color: #fff;
            border: none;
            padding: 12px 28px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
            display: block;
            margin: 0 auto;
        }
        
        .btn-primary:hover {
            background: var(--primary-hover);
            transform: scale(1.05);
        }
        
        .page-title {
            color: var(--primary);
            font-size: 24px;
            margin-bottom: 20px;
            text-align: left;
        }
        
        .categories-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 24px;
        }
        
        .category-card, .product-card {
            background: var(--card-bg);
            border: 2px solid var(--card-border);
            border-radius: 10px;
            padding: 12px 8px;
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
            position: relative;
        }
        
        .category-card:hover, .product-card:hover {
            border-color: var(--primary);
            transform: translateY(-3px);
        }
        
        .category-img, .product-img {
            width: 60px;
            height: 60px;
            border-radius: 8px;
            margin: 0 auto 10px;
            overflow: hidden;
            background: #2a1a2a;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .category-img img, .product-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .category-card p, .product-info p {
            font-size: 13px;
            font-weight: 600;
            line-height: 1.3;
        }
        
        .product-price {
            color: var(--primary);
            font-size: 13px;
            font-weight: bold;
            margin-top: 4px;
        }
        
        .product-stock {
            color: #00ff88;
            font-size: 11px;
            margin-top: 2px;
        }
        
        .product-stock.zero {
            color: #ff3333;
        }
        
        .btn-back {
            margin-bottom: 20px;
        }
        
        /* Admin Panel */
        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .admin-tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 20px;
            border-bottom: 2px solid #333;
        }
        
        .admin-tab {
            padding: 10px 16px;
            background: transparent;
            border: none;
            color: #bbb;
            cursor: pointer;
            font-weight: 600;
            border-bottom: 2px solid transparent;
        }
        
        .admin-tab.active {
            color: var(--primary);
            border-bottom: 2px solid var(--primary);
        }
        
        .admin-content {
            display: none;
        }
        
        .admin-content.active {
            display: block;
        }
        
        .form-group {
            margin-bottom: 16px;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 6px;
            color: var(--primary);
            font-size: 13px;
            font-weight: 600;
        }
        
        .form-group input, .form-group textarea, .form-group select {
            width: 100%;
            padding: 10px;
            background: #0a0a0a;
            border: 1px solid #333;
            border-radius: 6px;
            color: #fff;
            font-size: 13px;
        }
        
        .form-group textarea {
            resize: vertical;
            min-height: 60px;
        }
        
        .admin-list {
            margin-top: 20px;
        }
        
        .admin-item {
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 8px;
            padding: 12px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .admin-item-info {
            flex: 1;
        }
        
        .admin-item-info strong {
            color: var(--primary);
            font-size: 14px;
        }
        
        .admin-item-info small {
            color: #bbb;
            display: block;
            margin-top: 4px;
        }
        
        .admin-item-actions {
            display: flex;
            gap: 6px;
        }
        
        .stock-control {
            display: flex;
            gap: 6px;
            align-items: center;
            margin-top: 8px;
        }
        
        .stock-control input {
            width: 60px;
            padding: 4px;
            text-align: center;
        }
        
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
        }
        
        .modal-content {
            background: #1a1a1a;
            margin: 5% auto;
            padding: 24px;
            border: 1px solid var(--primary);
            border-radius: 10px;
            width: 90%;
            max-width: 500px;
            max-height: 80vh;
            overflow-y: auto;
        }
        
        .modal-content h3 {
            color: var(--primary);
            margin-bottom: 16px;
            font-size: 18px;
        }
        
        .modal-buttons {
            display: flex;
            gap: 8px;
            margin-top: 16px;
        }
        
        @media (max-width: 480px) {
            .categories-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
</head>
<body>
    <header>
        <div class="logo">Premium Store</div>
        <div class="header-buttons">
            <button class="btn-outline" onclick="toggleTheme()">🎨 Tema</button>
            <button class="btn-outline" onclick="openAdmin()">Admin</button>
        </div>
    </header>
    
    <main>
        <!-- PÁGINA INICIAL -->
        <div id="home" class="page active">
            <section class="hero">
                <h1>Premium Store</h1>
                <p class="subtitle">Loja virtual com atendimento direto no WhatsApp ⚡</p>
                
                <div class="card">
                    <h2>Como comprar na Premium Store:</h2>
                    <ol>
                        <li>Clique em "Ver Produtos" e escolha sua categoria</li>
                        <li>Selecione o produto que você gostou</li>
                        <li>Escolha: "Fazer Pagamento" via Pix ou "Comprar no WhatsApp"</li>
                        <li>No WhatsApp você fala direto comigo: <a href="https://wa.me/5598984853563">(98) 98485-3563</a></li>
                    </ol>
                    
                    <div class="security-box">
                        <h3>🔒 Compra 100% Manual e Segura</h3>
                        <p>Todas as vendas são confirmadas diretamente no WhatsApp pra sua segurança. Sem cartão cadastrado, sem risco.</p>
                    </div>
                </div>
                
                <button class="btn-primary" onclick="showPage('categorias')">Ver Produtos</button>
            </section>
        </div>

        <!-- PÁGINA CATEGORIAS -->
        <div id="categorias" class="page">
            <h2 class="page-title">Categorias</h2>
            <div class="categories-grid" id="categoriesGrid"></div>
            <button class="btn-outline" onclick="showPage('home')">Voltar ao Início</button>
        </div>

        <!-- PÁGINA PRODUTOS -->
        <div id="produtos" class="page">
            <button class="btn-outline btn-back" onclick="showPage('categorias')">← Voltar</button>
            <h2 class="page-title" id="produtosTitle">Produtos</h2>
            <div class="categories-grid" id="productsGrid"></div>
        </div>

        <!-- PAINEL ADMIN -->
        <div id="admin" class="page">
            <div class="admin-header">
                <h2 class="page-title">Painel Admin</h2>
                <button class="btn-outline" onclick="logoutAdmin()">Sair</button>
            </div>
            
            <div class="admin-tabs">
                <button class="admin-tab active" onclick="switchAdminTab('categories')">Categorias</button>
                <button class="admin-tab" onclick="switchAdminTab('products')">Produtos</button>
            </div>
            
            <!-- Aba Categorias -->
            <div id="adminCategories" class="admin-content active">
                <div class="card">
                    <h2 id="categoryFormTitle">Nova Categoria</h2>
                    <input type="hidden" id="categoryId">
                    <div class="form-group">
                        <label>Nome da Categoria</label>
                        <input type="text" id="categoryName" placeholder="Ex: Instagram">
                    </div>
                    <div class="form-group">
                        <label>URL da Imagem</label>
                        <input type="text" id="categoryImage" placeholder="img/instagram.png">
                    </div>
                    <button class="btn" onclick="saveCategory()">Salvar Categoria</button>
                    <button class="btn-outline" onclick="clearCategoryForm()" style="margin-left:8px">Cancelar</button>
                </div>
                
                <div class="admin-list" id="categoriesList"></div>
            </div>
            
            <!-- Aba Produtos -->
            <div id="adminProducts" class="admin-content">
                <div class="card">
                    <h2 id="productFormTitle">Novo Produto</h2>
                    <input type="hidden" id="productId">
                    <div class="form-group">
                        <label>Categoria</label>
                        <select id="productCategory"></select>
                    </div>
                    <div class="form-group">
                        <label>Nome do Produto</label>
                        <input type="text" id="productName" placeholder="Ex: 100 Seguidores">
                    </div>
                    <div class="form-group">
                        <label>URL da Imagem</label>
                        <input type="text" id="productImage" placeholder="img/produto.png">
                    </div>
                    <div class="form-group">
                        <label>Preço (R$)</label>
                        <input type="number" id="productPrice" placeholder="6.00" step="0.01">
                    </div>
                    <div class="form-group">
                        <label>Estoque</label>
                        <input type="number" id="productStock" placeholder="10">
                    </div>
                    <div class="form-group">
                        <label>Descrição</label>
                        <textarea id="productDesc" placeholder="Descrição do produto..."></textarea>
                    </div>
                    <button class="btn" onclick="saveProduct()">Salvar Produto</button>
                    <button class="btn-outline" onclick="clearProductForm()" style="margin-left:8px">Cancelar</button>
                </div>
                
                <div class="admin-list" id="productsList"></div>
            </div>
        </div>
    </main>

    <!-- Modal Login Admin -->
    <div id="loginModal" class="modal">
        <div class="modal-content">
            <h3>Login Admin</h3>
            <input type="text" id="adminUser" placeholder="Usuário">
            <input type="password" id="adminPass" placeholder="Senha">
            <div class="modal-buttons">
                <button class="btn" onclick="loginAdmin()" style="flex:1">Entrar</button>
                <button class="btn-outline" onclick="closeLogin()" style="flex:1">Cancelar</button>
            </div>
        </div>
    </div>

    <script>
        // Banco de dados local
        let db = {
            categories: [],
            products: []
        };
        
        // Inicializar dados padrão se não existir
        function initDB() {
            const saved = localStorage.getItem('premiumStoreDB');
            if (saved) {
                db = JSON.parse(saved);
            } else {
                db.categories = [
                    {id: 1, name: 'Instagram', image: 'img/instagram.png'},
                    {id: 2, name: 'Free Fire', image: 'img/freefire.png'},
                    {id: 3, name: 'TikTok', image: 'img/tiktok.png'},
                    {id: 4, name: 'Jogos', image: 'img/jogos.png'},
                    {id: 5, name: 'Kwai', image: 'img/kwai.png'}
                ];
                db.products = [
                    {id: 1, catId: 1, name: '100 Seguidores', price: 6.00, stock: 100, desc: 'Seguidores brasileiros reais', image: 'img/instagram.png'},
                    {id: 2, catId: 1, name: '200 Seguidores', price: 12.00, stock: 100, desc: 'Seguidores brasileiros reais', image: 'img/instagram.png'},
                    {id: 3, catId: 1, name: '300 Seguidores', price: 13.00, stock: 100, desc: 'Seguidores brasileiros reais', image: 'img/instagram.png'},
                    {id: 4, catId: 1, name: '400 Seguidores', price: 14.00, stock: 100, desc: 'Seguidores brasileiros reais', image: 'img/instagram.png'}
                ];
                saveDB();
            }
        }
        
        function saveDB() {
            localStorage.setItem('premiumStoreDB', JSON.stringify(db));
            renderCategories();
        }
        
        // Navegação
        function showPage(pageId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
            window.scrollTo(0, 0);
            if (pageId === 'categorias') renderCategories();
        }
        
        // Tema
        function toggleTheme() {
            document.body.classList.toggle('theme-blue');
            localStorage.setItem('theme', document.body.classList.contains('theme-blue') ? 'blue' : 'pink');
        }
        
        if(localStorage.getItem('theme') === 'blue') {
            document.body.classList.add('theme-blue');
        }
        
        // Admin Login
        function openAdmin() {
            if (sessionStorage.getItem('adminLogged') === 'true') {
                showPage('admin');
                renderAdminCategories();
                renderAdminProducts();
            } else {
                document.getElementById('loginModal').style.display = 'block';
            }
        }
        
        function closeLogin() {
            document.getElementById('loginModal').style.display = 'none';
        }
        
        function loginAdmin() {
            const user = document.getElementById('adminUser').value;
            const pass = document.getElementById('adminPass').value;
            
            if(user === 'Lorrannyh' && pass === 'Lorrannyh.101225') {
                sessionStorage.setItem('adminLogged', 'true');
                closeLogin();
                showPage('admin');
                renderAdminCategories();
                renderAdminProducts();
            } else {
                alert('Usuário ou senha incorretos!');
            }
        }
        
        function logoutAdmin() {
            sessionStorage.removeItem('adminLogged');
            showPage('home');
        }
        
        // Renderizar Categorias na loja
        function renderCategories() {
            const grid = document.getElementById('categoriesGrid');
            grid.innerHTML = '';
            db.categories.forEach(cat => {
                grid.innerHTML += `
                    <div class="category-card" onclick="showProducts(${cat.id})">
                        <div class="category-img">
                            <img src="${cat.image}" alt="${cat.name}" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22%3E%3Crect fill=%22%232a1a2a%22 width=%2260%22 height=%2260%22/%3E%3C/svg%3E'">
                        </div>
                        <p>${cat.name}</p>
                    </div>
                `;
            });
        }
        
        // Mostrar produtos de uma categoria
        function showProducts(catId) {
            const cat = db.categories.find(c => c.id === catId);
            document.getElementById('produtosTitle').textContent = cat.name;
            const grid = document.getElementById('productsGrid');
            grid.innerHTML = '';
            
            const products = db.products.filter(p => p.catId === catId);
            products.forEach(prod => {
                grid.innerHTML += `
                    <div class="product-card" onclick="buyProduct('${prod.name}', ${prod.price}, ${prod.id})">
                        <div class="product-img">
                            <img src="${prod.image}" alt="${prod.name}" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22%3E%3Crect fill=%22%232a1a2a%22 width=%2260%22 height=%2260%22/%3E%3C/svg%3E'">
                        </div>
                        <div class="product-info">
                            <p>${prod.name}</p>
                            <div class="product-price">R$ ${prod.price.toFixed(2)}</div>
                            <div class="product-stock ${prod.stock === 0 ? 'zero' : ''}">Estoque: ${prod.stock}</div>
                        </div>
                    </div>
                `;
            });
            showPage('produtos');
        }
        
        // Comprar produto
        function buyProduct(nome, preco, id) {
            const prod = db.products.find(p => p.id === id);
            if (prod.stock <= 0) {
                alert('Produto sem estoque!');
                return;
            }
            const msg = `Olá! Quero comprar: ${nome} - R$ ${preco.toFixed(2)}`;
            const link = `https://wa.me/5598984853563?text=${encodeURIComponent(msg)}`;
            window.open(link, '_blank');
        }
        
        // Admin - Abas
        function switchAdminTab(tab) {
            document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.admin-content').forEach(c => c.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById('admin' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
        }
        
        // Admin - Categorias
        function renderAdminCategories() {
            const list = document.getElementById('categoriesList');
            list.innerHTML = '';
            db.categories.forEach(cat => {
                list.innerHTML += `
                    <div class="admin-item">
                        <div class="admin-item-info">
                            <strong>${cat.name}</strong>
                            <small>${cat.image}</small>
                        </div>
                        <div class="admin-item-actions">
                            <button class="btn btn-small" onclick="editCategory(${cat.id})">Editar</button>
                            <button class="btn btn-small btn-danger" onclick="deleteCategory(${cat.id})">Deletar</button>
                        </div>
                    </div>
                `;
            });
            
            // Atualizar select de produtos
            const select = document.getElementById('productCategory');
            select.innerHTML = '';
            db.categories.forEach(cat => {
                select.innerHTML += `<option value="${cat.id}">${cat.name}</option>`;
            });
        }
        
        function saveCategory() {
            const id = document.getElementById('categoryId').value;
            const name = document.getElementById('categoryName').value;
            const image = document.getElementById('categoryImage').value;
            
            if (!name || !image) {
                alert('Preencha nome e imagem!');
                return;
            }
            
            if (id) {
                const cat = db.categories.find(c => c.id == id);
                cat.name = name;
                cat.image = image;
            } else {
                db.categories.push({
                    id: Date.now(),
                    name: name,
                    image: image
                });
            }
            
            saveDB();
            clearCategoryForm();
            renderAdminCategories();
        }
        
        function editCategory(id) {
            const cat = db.categories.find(c => c.id === id);
            document.getElementById('categoryId').value = cat.id;
            document.getElementById('categoryName').value = cat.name;
            document.getElementById('categoryImage').value = cat.image;
            document.getElementById('categoryFormTitle').textContent = 'Editar Categoria';
        }
        
        function deleteCategory(id) {
            if (!confirm('Deletar categoria e todos os produtos dela?')) return;
            db.categories = db.categories.filter(c => c.id !== id);
            db.products = db.products.filter(p => p.catId !== id);
            saveDB();
            renderAdminCategories();
        }
        
        function clearCategoryForm() {
            document.getElementById('categoryId').value = '';
            document.getElementById('categoryName').value = '';
            document.getElementById('categoryImage').value = '';
            document.getElementById('categoryFormTitle').textContent = 'Nova Categoria';
        }
        
        // Admin - Produtos
        function renderAdminProducts() {
            const list = document.getElementById('productsList');
            list.innerHTML = '';
            db.products.forEach(prod => {
                const cat = db.categories.find(c => c.id === prod.catId);
                list.innerHTML += `
                    <div class="admin-item">
                        <div class="admin-item-info">
                            <strong>${prod.name}</strong>
                            <small>${cat ? cat.name : 'Sem categoria'} | R$ ${prod.price.toFixed(2)} | Estoque: ${prod.stock}</small>
                        </div>
                        <div class="admin-item-actions">
                            <div class="stock-control">
                                <button class="btn btn-small" onclick="updateStock(${prod.id}, -1)">-</button>
                                <input type="number" value="${prod.stock}" onchange="setStock(${prod.id}, this.value)">
                                <button class="btn btn-small" onclick="updateStock(${prod.id}, 1)">+</button>
                            </div>
                            <button class="btn btn-small" onclick="editProduct(${prod.id})">Editar</button>
                            <button class="btn btn-small btn-danger" onclick="deleteProduct(${prod.id})">Deletar</button>
                        </div>
                    </div>
                `;
            });
        }
        
        function saveProduct() {
            const id = document.getElementById('productId').value;
            const catId = parseInt(document.getElementById('productCategory').value);
            const name = document.getElementById('productName').value;
            const image = document.getElementById('productImage').value;
            const price = parseFloat(document.getElementById('productPrice').value);
            const stock = parseInt(document.getElementById('productStock').value);
            const desc = document.getElementById('productDesc').value;
            
            if (!name || !image || !price || stock < 0) {
                alert('Preencha todos os campos corretamente!');
                return;
            }
            
            if (id) {
                const prod = db.products.find(p => p.id == id);
                prod.catId = catId;
                prod.name = name;
                prod.image = image;
                prod.price = price;
                prod.stock = stock;
                prod.desc = desc;
            } else {
                db.products.push({
                    id: Date.now(),
                    catId: catId,
                    name: name,
                    image: image,
                    price: price,
                    stock: stock,
                    desc: desc
                });
            }
            
            saveDB();
            clearProductForm();
            renderAdminProducts();
        }
        
        function editProduct(id) {
            const prod = db.products.find(p => p.id === id);
            document.getElementById('productId').value = prod.id;
            document.getElementById('productCategory').value = prod.catId;
            document.getElementById('productName').value = prod.name;
            document.getElementById('productImage').value = prod.image;
            document.getElementById('productPrice').value = prod.price;
            document.getElementById('productStock').value = prod.stock;
            document.getElementById('productDesc').value = prod.desc;
            document.getElementById('productFormTitle').textContent = 'Editar Produto';
        }
        
        function deleteProduct(id) {
            if (!confirm('Deletar este produto?')) return;
            db.products = db.products.filter(p => p.id !== id);
            saveDB();
            renderAdminProducts();
        }
        
        function updateStock(id, change) {
            const prod = db.products.find(p => p.id === id);
            prod.stock = Math.max(0, prod.stock + change);
            saveDB();
            renderAdminProducts();
        }
        
        function setStock(id, value) {
            const prod = db.products.find(p => p.id === id);
            prod.stock = Math.max(0, parseInt(value) || 0);
            saveDB();
            renderAdminProducts();
        }
        
        function clearProductForm() {
            document.getElementById('productId').value = '';
            document.getElementById('productName').value = '';
            document.getElementById('productImage').value = '';
            document.getElementById('productPrice').value = '';
            document.getElementById('productStock').value = '';
            document.getElementById('productDesc').value = '';
            document.getElementById('productFormTitle').textContent = 'Novo Produto';
        }
        
        window.onclick = function(event) {
            if (event.target == document.getElementById('loginModal')) {
                closeLogin();
            }
        }
        
        // Inicializar
        initDB();
        renderCategories();
    </script>
</body>
</html>